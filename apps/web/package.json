  "description": "Template",
  "scripts": {
    "dev": "run-p dev:**",
    "dev:next": "bun next dev -H 0.0.0.0",
    "dev:typecheck": "bun typecheck",
    "dev:api-typegen": "bun -b tsc -w --preserveWatchOutput -p tsconfig.api.json",
