{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",

    // Bundler mode
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,

    "types": ["bun"],
    "paths": {
      "@/api/*": ["./src/*"]
    }
  }
}
