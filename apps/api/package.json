{
  "name": "@purrfect_match/api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "bun run --hot src/app.ts",
    "start": "bun run src/app.ts",
    "test": "bun run --bun vitest",
    "studio": "drizzle-kit studio",
    "typecheck": "bun --bun tsc --noEmit -w --preserveWatchOutput -p tsconfig.json",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@hono/zod-validator": "^0.8.0",
    "@purrfect_match/shared": "workspace:*",
    "better-auth": "^1.6.22",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  }
}
